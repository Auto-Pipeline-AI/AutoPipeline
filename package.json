{
  "name": "autopipeline",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "setup": "npm install && npm run build",
    "dev": "electron electron/main.js --dev",
    "start": "electron electron/main.js",
    "build-backend": "cd apps/backend && (test -f .env || cp .env-example .env) && npm install && npx prisma generate && npm run build",
    "build-frontend": "cd apps/frontend && (test -f .env || cp .env-example .env) && npm install && npm run build",
    "build-agent": "cd apps/agent && pip install -r requirements.txt",
    "build": "npm run build-backend && npm run build-frontend && npm run build-agent",
    "package": "electron-builder"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auto-Pipeline-AI/AutoPipeline.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Auto-Pipeline-AI/AutoPipeline/issues"
  },
  "homepage": "https://github.com/Auto-Pipeline-AI/AutoPipeline#readme",
  "devDependencies": {
    "electron": "^40.1.0",
    "electron-builder": "^26.7.0"
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  }
}