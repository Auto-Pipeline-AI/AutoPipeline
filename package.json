    "update": "node scripts/setup.js --update",
    "start": "node scripts/run.js",
    "dev": "node scripts/run.js",
    "clean": "node scripts/clean.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Auto-Pipeline-AI/AutoPipeline.git"
  },
