{
    "appId": "com.autopipeline.app",
    "productName": "AutoPipeline",
    "directories": {
        "output": "dist"
    },
    "files": [
        "electron/**/*",
        "apps/frontend/.next/**/*",
        "apps/frontend/public/**/*",
        "apps/frontend/package.json",
        "apps/backend/dist/**/*",
        "apps/backend/node_modules/**/*",
        "apps/backend/package.json"
    ],
    "extraResources": [
        {
            "from": "apps/frontend/node_modules",
            "to": "apps/frontend/node_modules"
        }
    ],
    "win": {
        "target": "nsis"
    },
    "mac": {
        "target": "dmg"
    },
    "linux": {
        "target": "AppImage"
    }
}